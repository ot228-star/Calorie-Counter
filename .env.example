EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_ENV=development
# Optional: set to true to skip login while developing UI (do not use for testing Google sign-in).
EXPO_PUBLIC_AUTH_DISABLED=false
# When "false", food lists skip source.unsplash.com/random and picsum (use DB image_url / maps only).
EXPO_PUBLIC_ALLOW_PLACEHOLDER_FOOD_IMAGES=true
AI_PROVIDER_API_KEY=
AI_PROVIDER_BASE_URL=
IMAGE_RETENTION_DAYS=7
ESTIMATE_TIMEOUT_MS=12000
