EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_ENV=development
# Optional: set to true to skip login while developing UI (do not use for testing Google sign-in).
EXPO_PUBLIC_AUTH_DISABLED=false
# When "false", food lists skip source.unsplash.com/random and picsum (use DB image_url / maps only).
EXPO_PUBLIC_ALLOW_PLACEHOLDER_FOOD_IMAGES=true
AI_PROVIDER_API_KEY=
AI_PROVIDER_BASE_URL=
IMAGE_RETENTION_DAYS=7
ESTIMATE_TIMEOUT_MS=12000

# AdMob app + unit IDs (production). Use Google's official test IDs in dev.
# Test app IDs:
#   Android: ca-app-pub-3940256099942544~3347511713
#   iOS:     ca-app-pub-3940256099942544~1458002511
# Test banner unit IDs:
#   Android: ca-app-pub-3940256099942544/6300978111
#   iOS:     ca-app-pub-3940256099942544/2934735716
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=
EXPO_PUBLIC_ADMOB_IOS_APP_ID=
EXPO_PUBLIC_ADMOB_BANNER_ANDROID=
EXPO_PUBLIC_ADMOB_BANNER_IOS=

# Public legal URLs shown in Settings and submitted to Apple/Google.
EXPO_PUBLIC_PRIVACY_POLICY_URL=
EXPO_PUBLIC_TERMS_URL=
EXPO_PUBLIC_SUPPORT_EMAIL=strive.fitness.contact@gmail.com
